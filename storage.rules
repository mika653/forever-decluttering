rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Item photos: public read, only the store owner can write
    match /stores/{storeSlug}/items/{itemId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/stores/$(storeSlug)).data.ownerId == request.auth.uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
